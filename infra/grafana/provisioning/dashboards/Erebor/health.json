{
  "uid": "erebor-health",
  "title": "Erebor Service Health",
  "tags": ["erebor", "health"],
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "BTCUSDT Status",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "Degraded", "color": "red", "index": 0 },
                "1": { "text": "Synced", "color": "green", "index": 1 }
              }
            }
          ],
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT CASE WHEN MAX(event_time) IS NULL OR EXTRACT(EPOCH FROM (NOW() - MAX(event_time))) >= 30 THEN 0 ELSE 1 END AS status FROM order_book_diffs WHERE symbol = 'BTCUSDT' AND event_time > NOW() - INTERVAL '5 minutes'",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "ETHUSDT Status",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "Degraded", "color": "red", "index": 0 },
                "1": { "text": "Synced", "color": "green", "index": 1 }
              }
            }
          ],
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT CASE WHEN MAX(event_time) IS NULL OR EXTRACT(EPOCH FROM (NOW() - MAX(event_time))) >= 30 THEN 0 ELSE 1 END AS status FROM order_book_diffs WHERE symbol = 'ETHUSDT' AND event_time > NOW() - INTERVAL '5 minutes'",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "BTCUSDT Data Lag",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT ROUND(EXTRACT(EPOCH FROM (NOW() - COALESCE(MAX(event_time), NOW() - INTERVAL '24 hours')))::numeric, 1) AS lag_seconds FROM order_book_diffs WHERE symbol = 'BTCUSDT'",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "ETHUSDT Data Lag",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT ROUND(EXTRACT(EPOCH FROM (NOW() - COALESCE(MAX(event_time), NOW() - INTERVAL '24 hours')))::numeric, 1) AS lag_seconds FROM order_book_diffs WHERE symbol = 'ETHUSDT'",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Diff Ingestion Rate",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT time_bucket('10 seconds', event_time) AS \"time\", COUNT(*) / 10.0 AS value, symbol AS metric FROM order_book_diffs WHERE $__timeFilter(event_time) GROUP BY 1, symbol ORDER BY 1",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Processing Latency (event_time → received_at)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT time_bucket('10 seconds', event_time) AS \"time\", AVG(EXTRACT(EPOCH FROM (received_at - event_time)) * 1000) AS value, symbol AS metric FROM order_book_diffs WHERE $__timeFilter(event_time) GROUP BY 1, symbol ORDER BY 1",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Snapshot Checkpoint Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto",
            "spanNulls": false
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT time_bucket('1 minute', snapshot_time) AS \"time\", COUNT(*) AS value, symbol AS metric FROM order_book_snapshots WHERE $__timeFilter(snapshot_time) GROUP BY 1, symbol ORDER BY 1",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "Last Snapshot Age",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "options": {
        "footer": { "show": false },
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "seconds_since_snapshot" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "decimals", "value": 0 },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background" }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 60 },
                    { "color": "red", "value": 120 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT symbol, ROUND(EXTRACT(EPOCH FROM (NOW() - COALESCE(MAX(snapshot_time), NOW() - INTERVAL '24 hours')))::numeric, 0) AS seconds_since_snapshot FROM order_book_snapshots GROUP BY symbol ORDER BY symbol",
          "refId": "A"
        }
      ]
    }
  ]
}
